# Broker Pipeline — environment variables
# Copy to .env and fill in your values.

# Required — OpenAI API key for embeddings & AI answers
OPENAI_API_KEY=

# Postgres (defaults match docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# External port exposed on the host (change if 5432 is occupied)
POSTGRES_PORT_EXTERNAL=5432

# Broker API port exposed on the host
BROKER_PORT=8000
